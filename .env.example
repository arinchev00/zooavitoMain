# ============================================
# JWT Authentication
# ============================================
# JWT Secret (сгенерируйте свой для разработки)
# Минимум 32 символа, можно использовать openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_chars_long
# Время жизни токена в миллисекундах (86400000 = 24 часа)
JWT_EXPIRATION=86400000

# ============================================
# Google reCAPTCHA
# ============================================
# Получите свои ключи на https://www.google.com/recaptcha/admin
# Секретный ключ для серверной валидации (Secret Key)
GOOGLE_RECAPTCHA_SECRET=your_secret_key_here
# Публичный ключ для фронтенда (Site Key)
REACT_APP_RECAPTCHA_SITE_KEY=your_site_key_here

# ============================================
# Database (PostgreSQL)
# ============================================
# Хост базы данных (для docker-compose используйте имя сервиса "db")
DB_POSTGRES_HOST=db
# Порт PostgreSQL внутри контейнера
DB_POSTGRES_PORT=5432
# Имя пользователя базы данных
DB_POSTGRES_USER=postgres
# Пароль пользователя базы данных
DB_POSTGRES_PASSWORD=postgres
# Имя базы данных
DB_POSTGRES_DATABASE=zooavito

# ============================================
# Spring Boot Backend
# ============================================
# Полный URL подключения к базе данных
SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_POSTGRES_HOST}:${DB_POSTGRES_PORT}/${DB_POSTGRES_DATABASE}
# Имя пользователя базы данных
SPRING_DATASOURCE_USERNAME=${DB_POSTGRES_USER}
# Пароль базы данных
SPRING_DATASOURCE_PASSWORD=${DB_POSTGRES_PASSWORD}